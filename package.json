{
  "name": "anubis-consent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/js/anubis.bundled.js",
  "module": "dist/js/anubis.esm.js",
  "scripts": {
    "build": "node build.config.js",
    "build:esm": "esbuild src/js/index.js --bundle --format=esm --outfile=dist/js/anubis.esm.js --minify",
    "build:iife": "esbuild src/js/index.js --bundle --format=iife --global-name=AnubisConsent --outfile=dist/js/anubis.js --minify",
    "build:iife:bundled": "node build.config.js",
    "build:debug": "esbuild src/js/debug-helper.js --bundle --format=iife --outfile=dist/js/debugger.js --minify"
  },
  "devDependencies": {
    "esbuild": "^0.25.1"
  }
}
